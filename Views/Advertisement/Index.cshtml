@model IEnumerable<HostelFinderApp.Models.Advertisement>

@{
    ViewData["Title"] = "Advertisements";
}

<h1>Advertisements</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Post New Advertisement</a>
</p>

<div class="table-responsive shadow-sm bg-white rounded">
    <table class="table table-striped table-hover mb-0">
        <thead class="table table-striped">
        <tr>
            <th>Title</th>
            <th>Location</th>
            <th>Price</th>
            <th>User</th>
            <th>Date Posted</th>
            <th class="text-end text-nowrap" style="width: 1%;">Actions</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                <strong>@Html.DisplayFor(modelItem => item.Title)</strong><br />
                <small class="text-muted">@Html.DisplayFor(modelItem => item.Description)</small>
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Location)
            </td>
            <td>
                @item.Price.ToString("C")
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.UserName)
            </td>
            <td>
                @item.DatePosted.ToString("g")
            </td>
            <td class="text-end align-middle" style="white-space: nowrap; width: 1%;">
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white rounded-pill px-3 shadow-sm d-inline-block">View</a>
            </td>
        </tr>
}
    </tbody>
    </table>
</div>
