@model HostelFinderApp.Models.Advertisement

@{
    ViewData["Title"] = "Post Advertisement";
}

<h1>Post a New Advertisement</h1>

<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="form-floating mb-3">
                <input asp-for="Title" class="form-control" placeholder="E.g., Large Room in Downtown" />
                <label asp-for="Title" class="control-label"></label>
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            
            <div class="form-floating mb-3">
                <textarea asp-for="Description" class="form-control" style="height: 100px" placeholder="Describe the place..."></textarea>
                <label asp-for="Description" class="control-label"></label>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            
            <div class="form-floating mb-3">
                <input asp-for="Location" class="form-control" placeholder="E.g., 123 Main St" />
                <label asp-for="Location" class="control-label"></label>
                <span asp-validation-for="Location" class="text-danger"></span>
            </div>
            
            <div class="form-floating mb-3">
                <input asp-for="Price" class="form-control" placeholder="E.g., 500" />
                <label asp-for="Price" class="control-label"></label>
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label for="imageFiles" class="form-label">Upload Images (Optional)</label>
                <input type="file" class="form-control" id="imageFiles" name="imageFiles" accept="image/*" multiple />
            </div>
            
            <hr class="my-4" />
            <h4 class="mb-3">Contact Information</h4>
            
            <div class="row g-3 mb-4">
                <div class="col-md-6 form-floating">
                    <input asp-for="ContactPhone" class="form-control" placeholder="E.g., +1 234 567 8900" />
                    <label asp-for="ContactPhone" class="control-label ms-2"></label>
                    <span asp-validation-for="ContactPhone" class="text-danger"></span>
                </div>
                <div class="col-md-6 form-floating">
                    <input asp-for="ContactEmail" class="form-control" placeholder="E.g., name@example.com" />
                    <label asp-for="ContactEmail" class="control-label ms-2"></label>
                    <span asp-validation-for="ContactEmail" class="text-danger"></span>
                </div>
            </div>
            
            <div class="form-group mb-3 text-end">
                <a asp-action="Index" class="btn btn-secondary me-2 rounded-pill px-4">Cancel</a>
                <input type="submit" value="Post Ad" class="btn btn-success rounded-pill px-5 fw-bold" />
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
